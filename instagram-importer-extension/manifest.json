{
  "manifest_version": 3,
  "name": "MeetMap Flyer Importer",
  "version": "0.1.0",
  "description": "Import Instagram flyer images into MeetMap (approval queue).",
  "permissions": ["tabs"],
  "host_permissions": ["https://www.instagram.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
