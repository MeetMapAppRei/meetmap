# Copy to .env.migrate (gitignored) — used only by scripts/migrate-supabase-images-to-r2.mjs
# NEVER commit .env.migrate

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=meetmap-media
# Public URL base (R2 dev subdomain or custom domain), no trailing slash
# Example: https://pub-xxxxxxxxxxxx.r2.dev
R2_PUBLIC_BASE_URL=

# Set to 1 for a dry run (no uploads, no DB writes)
# DRY_RUN=1
