# Supabase (required for auth + data)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Mapbox map token (public token; restrict by URL in Mapbox dashboard)
VITE_MAPBOX_TOKEN=

# Production site origin — REQUIRED for Capacitor builds so /api/* calls reach your host
# Example: https://findcarmeets.com  (no trailing slash)
# Leave empty for local web dev (uses relative /api with Vite proxy or host)
VITE_APP_ORIGIN=

# Optional: import queue admins
# VITE_IMPORT_ADMIN_EMAILS=
# VITE_IMPORT_ADMIN_USER_IDS=

# --- Cloudflare R2 (optional; stops Supabase Storage image egress) ---
# After configuring R2 + Vercel env (see docs/R2-MIGRATION.md), set:
# VITE_USE_R2_STORAGE=true
# Server-only on Vercel: R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY,
# R2_BUCKET_NAME, R2_PUBLIC_BASE_URL, plus SUPABASE_URL + SUPABASE_ANON_KEY (or VITE_*)
